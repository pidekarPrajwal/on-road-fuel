<%= layout("./layout/boilerplate.ejs") %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h1 class="heading">Edit Profile for On Road Fuel .!</h1>
    <form
      action="/GetFuel/<%=result[0].email%>/edit"
      method="post"
      class="needs-validation"
      novalidate
    >
      <div class="mb-3">
        <label for="name" class="form-label">Name :</label>
        <input
          name="name"
          placeholder="Enter a Name :  "
          id="name"
          value="<%= result[0].name %> "
          type="text"
          required
          class="form-control"
        />
        <div class="valid-feedback">Looks good!</div>
      </div>

      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          name="username"
          placeholder="Enter a Username "
          id="username"
          value="<%= result[0].username %>"
          type="text"
          required
          class="form-control"
        />
        <div class="valid-feedback">Looks good!</div>
      </div>

      <div class="mb-3">
        <label for="email" class="form-label">E-Mail</label>
        <input
          name="email"
          placeholder="Enter a Email "
          value="<%= result[0].email %>"
          id="username"
          type="email"
          readonly
          required
          class="form-control"
        />
        <div class="valid-feedback">Looks good!</div>
      </div>

      <div class="mb-3">
        <label for="mobile" class="form-label">Mobile No. : </label>
        <input
          name="mobno"
          placeholder="Enter a Mobile Number "
          id="mobno"
          value="<%= result[0].mobno %>"
          type="number"
          required
          class="form-control"
        />
        <div class="valid-feedback" id="message">Looks Good !</div>
      </div>
      <br />
      <h3 class="heading">Change Password .!</h3>
<hr>
<!-- Before changing pass user add to old pass then show change password div -->

<div class="askuser mb-3">
  <h4 style="color: red;">If you want to change Password </h4>
  <input type="text" name="oldpass" id="oldpass" placeholder="Fill Old Password" class="form-control">
  <div class="btn btn-dark">Show Change Password</div>
</div>

      <!-- Check validity for user  -->
      <div class="checkpass" style="visibility: hidden;"> 
        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input
            name="password"
            placeholder="Enter a Password "
            id="password"
            type="password"
            required
            class="form-control"
          />
          <div class="valid-feedback" id="message">Looks Good !</div>
        </div> 
        <!-- confrom password -->
        <div class="mb-3">
          <label for="cfpass" class="form-label"> Confrim Password</label>
          <input
            name="cfpass"
            placeholder="Enter a Confrim Password "
            id="cfpass"
            type="text"
            required
            class="form-control"
          />
          <div class="valid-feedback" id="message">Looks Good !</div>
        </div>
      </div>

      <button
        class="btn btn-success p-2 del-btn"
        id="btn"
        onclick="checkPass(event)"
      >
        Edit Profile..!
      </button>
      <br /><br />
    </form>
  </div>
</div>

<!-- Blackbox -->
<script>
  function checkPass(event) {
    const password = document.getElementById("password");
    const confirmPassword = document.getElementById("cfpass");
    const message = document.getElementById("message");
    // Clear previous messages
    message.innerHTML = "";
    if (password.value !== confirmPassword.value) {
      alert("Passwords do not match");
      message.innerHTML = "Passwords do not match!";
      message.style.color = "red";
      event.preventDefault(); // Prevent form submission
      return false; // Return false to indicate failure
    } else {
      message.innerHTML = "Passwords match!";
      message.style.color = "green"; // Optional: Change color for success
    }
  }
</script>

