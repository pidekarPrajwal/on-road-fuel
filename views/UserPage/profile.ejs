<%= layout("./layout/boilerplate.ejs") %>

<div class="page-content page-container" id="page-content">
  <div class="padding">
    <div class="row container d-flex justify-content-center">
      <div class="col-xl-10 col-md-12">
        <div class="card user-card-full">
          <div class="row m-2-0 m-r-0">
            <div class="col-sm-4 bg-c-lite-green user-profile">
              <div class="card-block text-center text-white">
                <div class="m-b-25">
                  <img
                  src="https://img.icons8.com/bubbles/100/000000/user.png"
                  class="img-radius"
                  alt="User-Profile-Image"
                  />
                </div>
                <span>Fuel order by </span>
                <h4 class="f-w-600"> - <%= result[0].name %></h4>
                <!-- <p>Web Designer</p> -->
                <i
                  class="mdi mdi-square-edit-outline feather icon-edit m-t-10 f-16"
                ></i>
              </div>
            </div>
            <div class="col-sm-8">
              <div class="card-block">
                <h6 class="m-b-20 p-b-5 b-b-default f-w-600">
                  Fuel User Information
                </h6>
                <div class="row">
                  <div class="col-sm-6">
                    <p class="m-b-10 f-w-800">Email</p>
                    <h6 class="text-muted f-w-400"><%= result[0].email%></h6>
                  </div>
                  <div class="col-sm-6">
                    <p class="m-b-10 f-w-600">Mobile No.</p>
                    <h6 class="text-muted f-w-400"><%= result[0].mobno%></h6>
                  </div>
                </div>
                <h6 class="m-b-20 m-t-40 p-b-5 b-b-default f-w-600">
                  About Fuel
                </h6>
                <div class="row">
                  <div class="col-sm-6">
                    <a
                      href="/GetFuel/<%=result[0].email%>/edit"
                      class="btn btn-dark col-8 offset-3 edit-btn"
                      >Edit User Details</a
                    >
                  </div>
                  <div class="col-sm-6">
                    <a href="/GetFuel/<%=result[0].email%>">
                      <button class="btn btn-dark">GET FUEL</button>
                    </a>
                  </div>
                </div>
                <ul class="social-link list-unstyled m-t-40 m-b-10">
                  <li>
                    <a
                      href="#!"
                      data-toggle="tooltip"
                      data-placement="bottom"
                      title=""
                      data-original-title="facebook"
                      data-abc="true"
                      ><i
                        class="mdi mdi-facebook feather icon-facebook facebook"
                        aria-hidden="true"
                      ></i
                    ></a>
                  </li>
                  <li>
                    <a
                      href="#!"
                      data-toggle="tooltip"
                      data-placement="bottom"
                      title=""
                      data-original-title="twitter"
                      data-abc="true"
                      ><i
                        class="mdi mdi-twitter feather icon-twitter twitter"
                        aria-hidden="true"
                      ></i
                    ></a>
                  </li>
                  <li>
                    <a
                      href="#!"
                      data-toggle="tooltip"
                      data-placement="bottom"
                      title=""
                      data-original-title="instagram"
                      data-abc="true"
                      ><i
                        class="mdi mdi-instagram feather icon-instagram instagram"
                        aria-hidden="true"
                      ></i
                    ></a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
